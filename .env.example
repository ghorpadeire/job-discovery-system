# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jobsdb
DB_USER=jobsuser
DB_PASSWORD=jobspass

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── OpenAI (required for AI careers scraper) ──────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...

# ── Telegram (optional — notifications) ──────────────────────────────────────
# 1. Create a bot via @BotFather → copy the token below
# 2. Send your bot any message, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    Copy the numeric "id" from the "chat" object into TELEGRAM_CHAT_ID
TELEGRAM_BOT_TOKEN=123456789:ABC-your-token-here
TELEGRAM_CHAT_ID=987654321

# ── Scoring thresholds ────────────────────────────────────────────────────────
ALERT_SCORE=85       # instant Telegram alert threshold
DIGEST_SCORE=70      # daily digest minimum score
GHOST_THRESHOLD=30   # score below this = suspected ghost listing

# ── Dashboard ─────────────────────────────────────────────────────────────────
PORT=5000
SECRET_KEY=change-me-in-production
FLASK_ENV=development

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
