# ─────────────────────────────────────────────────────────────────────────────
# Job Discovery System — Environment Variables
#
# Copy this file:  cp .env.example .env
# Fill in your values, then:
#   Docker:  docker compose up -d
#   Local:   py dashboard.py
#
# NEVER commit .env to git — it is in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Docker:  host = "postgres" (service name)
# Local:   host = "localhost"
POSTGRES_DB=jobsdb
POSTGRES_USER=jobsuser
POSTGRES_PASSWORD=jobspass
DATABASE_URL=postgresql://jobsuser:jobspass@localhost:5432/jobsdb

# ── Redis ─────────────────────────────────────────────────────────────────────
# Docker:  host = "redis"
# Local:   host = "localhost"
REDIS_URL=redis://localhost:6379/0

# ── OpenAI (Phase 4 — AI relevance + ghost scoring) ──────────────────────────
# Get your key at: https://platform.openai.com/api-keys
# Used models: text-embedding-3-small (embeddings), gpt-4o-mini (reasoning)
# Cost estimate: ~$0.01–$0.05 per full rescore of 200 jobs
OPENAI_API_KEY=sk-...

# ── Telegram Bot (Phase 5 — notifications) ────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy the token below
# 2. Start a chat with your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    Look for "chat": {"id": 123456789} — that is your CHAT_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional alert / digest thresholds (defaults shown)
TG_DIGEST_MIN_SCORE=70    # minimum combined score for daily digest
TG_ALERT_MIN_SCORE=85     # minimum combined score for instant alert
TG_ALERT_POLL_MINS=5      # how often (minutes) to check for new high-score jobs
TG_DIGEST_HOUR=9          # 24-h hour for daily digest (local time)
TG_DIGEST_MINUTE=0        # minute for daily digest

# ── Scraper service ───────────────────────────────────────────────────────────
SCRAPE_INTERVAL_HOURS=12  # how often the scraper runs
SCRAPE_SOURCES=all         # all | ij | indeed

# ── Scorer service ────────────────────────────────────────────────────────────
SCORER_FALLBACK_HOURS=6   # fallback run interval (in addition to Redis trigger)
AI_SCORE_ENABLED=false    # set to "true" to enable AI scoring in scorer service

# ── Flask dashboard ───────────────────────────────────────────────────────────
DASHBOARD_PORT=5000
FLASK_ENV=development      # development | production
